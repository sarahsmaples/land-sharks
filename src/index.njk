      <p class="section-subtitle text-center">Questions? We'd love to hear from you.</p>
    </div>
    <iframe src="https://reservationgenie.com/{{ client.rgPath }}/contact_form" width="100%" height="610" frameborder="0" style="border: none;"></iframe>
  </section>

{% endblock %}
