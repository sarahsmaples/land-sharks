<footer class="relative z-10 text-white -mt-10">

  <!-- Wave overlaps whatever section is above -->
  <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="block w-full -mb-px">
    <path d="M0,30 C360,0 1080,60 1440,30 L1440,60 L0,60 Z" fill="#071540"/>
  </svg>

  <div class="bg-navy-900">
  <div class="max-w-screen-xl mx-auto px-4 py-12 lg:px-6">
    <div class="grid md:grid-cols-3 gap-10 mb-10">

      <!-- Brand + contact -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-3xl leading-none">⚓</span>
          <span class="font-heading text-2xl">{{ client.name }}</span>
        </div>
        <p class="text-navy-200 text-sm mb-5 leading-relaxed">Santa Barbara's original amphibious tour. Land, sea, and everything in between since 2002.</p>
        <address class="not-italic text-sm space-y-1">
          <p class="text-navy-200">{{ client.address.street }}</p>
          <p class="text-navy-200">{{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}</p>
          <a href="tel:{{ client.phone }}" class="text-teal-300 hover:text-white transition-colors block mt-2">{{ client.phone }}</a>
        </address>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-heading text-xl mb-5 text-teal-300">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="{{ "/" | url }}" class="text-navy-200 hover:text-white transition-colors">Home</a></li>
          <li><a href="{{ "/public-tours/" | url }}" class="text-navy-200 hover:text-white transition-colors">Public Tours</a></li>
          <li><a href="{{ "/charter/" | url }}" class="text-navy-200 hover:text-white transition-colors">Private Charters</a></li>
          <li><a href="{{ "/vessels/" | url }}" class="text-navy-200 hover:text-white transition-colors">Vessels &amp; Vehicles</a></li>
          <li><a href="{{ "/gallery/" | url }}" class="text-navy-200 hover:text-white transition-colors">Gallery</a></li>
          <li><a href="{{ "/faq/" | url }}" class="text-navy-200 hover:text-white transition-colors">FAQ</a></li>
          <li><a href="{{ "/gift-cards/" | url }}" class="text-navy-200 hover:text-white transition-colors">Gift Cards</a></li>
          <li><a href="{{ "/employment/" | url }}" class="text-navy-200 hover:text-white transition-colors">Employment</a></li>
        </ul>
      </div>

      <!-- Book CTA -->
      <div>
        <h3 class="font-heading text-xl mb-5 text-teal-300">Ready to Ride?</h3>
        <p class="text-navy-200 text-sm mb-6 leading-relaxed">Book your adventure online and get ready for the most unique tour in Santa Barbara.</p>
        <a href="https://book.{{ client.bookingDomain }}.com/{{ client.rgPath }}/reservations/calendar" target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-7 py-3">
          Book Now &rarr;
        </a>
      </div>

    </div>

    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2 text-navy-300 text-xs">
      <span>&copy; {{ global.currentYear }} {{ client.name }}. All Rights Reserved.</span>
      <span>Website designed and hosted by <a href="https://reservationgenie.com/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Reservation Genie</a></span>
    </div>
  </div>
  </div>

</footer>
