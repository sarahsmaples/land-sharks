<div class="relative text-white overflow-hidden">

  <!-- Background image -->
  <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ ("/assets/images/" + (heroImage if heroImage else "santa-barbara.jpg")) | url }}');"></div>
  <div class="absolute inset-0 bg-navy-900/55"></div>

  <div class="relative z-10 max-w-screen-xl mx-auto px-4 lg:px-6 py-28">
    {% if badge %}
      <span class="inline-block bg-teal text-white text-sm font-bold uppercase tracking-widest px-5 py-2 mb-4" style="border-radius: 79px 15px 79px 15px;">{{ badge }}</span>
    {% endif %}
    <h1 class="text-4xl lg:text-5xl font-heading">{{ title }}</h1>
  </div>

  <!-- Wave bottom into white -->
  <svg viewBox="0 0 1440 50" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="relative z-10 block w-full -mb-px">
    <path d="M0,25 C360,50 1080,0 1440,25 L1440,50 L0,50 Z" fill="#E0F8F8"/>
  </svg>

</div>
