<div class="fixed top-0 left-0 right-0 z-50">

  <!-- Logo: anchored to top of entire header, overhangs nav -->
  <a href="{{ "/" | url }}" class="absolute top-0 left-6 z-20 hidden md:block">
    <img src="{{ "/assets/images/logo-nav.png" | url }}" alt="{{ client.name }}" class="h-[140px] w-auto drop-shadow-lg">
  </a>

  <!-- Pre-header bar -->
  <div class="bg-teal text-sm text-white hidden md:block">
    <div class="max-w-screen-xl mx-auto px-4 py-2 flex items-center justify-center">
      <div class="flex items-center gap-6">
        <a href="tel:{{ client.phone | replace('-', '') }}" class="flex items-center gap-2 hover:text-white/75 transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          {{ client.phone }}
        </a>
        <a href="https://maps.app.goo.gl/4CB2W3KLr5J28GYb6" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white/75 transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          {{ client.address.street }}, {{ client.address.city }}, {{ client.address.state }}
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="bg-[#0E2660] shadow-lg">
    <div class="max-w-screen-xl flex items-stretch justify-between mx-auto px-4">

      <!-- Logo placeholder to reserve space on desktop -->
      <div class="hidden md:block shrink-0 w-[130px]"></div>

      <!-- Mobile logo -->
      <a href="{{ "/" | url }}" class="flex items-center shrink-0 md:hidden">
        <img src="{{ "/assets/images/logo-nav.png" | url }}" alt="{{ client.name }}" class="h-12 w-auto">
      </a>

      <!-- Mobile hamburger -->
      <button data-collapse-toggle="navbar-default" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-white rounded-lg md:hidden hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-teal" aria-controls="navbar-default" aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>

      <!-- Nav links + CTA -->
      <div class="hidden w-full md:flex md:w-auto md:items-stretch md:justify-between md:flex-1" id="navbar-default">
        <ul class="flex flex-col md:flex-row md:items-stretch md:-ml-[50px]">
          <li class="bg-[#0E2660]"><a href="{{ "/" | url }}" class="nav-link md:pl-[74px]"><span>Home</span></a></li>
          <li class="bg-blue-900"><a href="{{ "/public-tours/" | url }}" class="nav-link"><span>Public Tours</span></a></li>
          <li class="bg-blue-800"><a href="{{ "/vessels/" | url }}" class="nav-link"><span>Vessels</span></a></li>
          <li class="bg-blue-700"><a href="{{ "/faq/" | url }}" class="nav-link"><span>FAQ</span></a></li>
          <li class="bg-blue-600"><a href="{{ "/charter/" | url }}" class="nav-link"><span>Private Charter</span></a></li>
          <li class="bg-blue-500"><a href="{{ "/gallery/" | url }}" class="nav-link"><span>Gallery</span></a></li>
          <li class="bg-blue-400"><a href="{{ "/gift-cards/" | url }}" class="nav-link"><span>Gift Cards</span></a></li>
        </ul>

        <a href="https://book.{{ client.bookingDomain }}.com/{{ client.rgPath }}/reservations/calendar" target="_blank" rel="noopener noreferrer" class="hidden md:flex md:items-center shrink-0 px-5 py-2 bg-coral text-white font-bold text-sm hover:bg-coral-600 transition-colors shadow hover:shadow-md">
          Book Now
        </a>
      </div>

    </div>
  </nav>

</div>

<!-- Spacer to prevent content from hiding behind fixed header -->
<div class="h-[72px] md:h-[100px]"></div>
